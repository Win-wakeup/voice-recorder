{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "api/upload.js", "use": "@vercel/node" },
    { "src": "api/index.py", "use": "@vercel/python", "config": { "maxDuration": 60 } }
  ],
  "routes": [
    { "src": "/api/upload", "dest": "/api/upload.js" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/register", "dest": "/server.js" },
    { "src": "/user/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}